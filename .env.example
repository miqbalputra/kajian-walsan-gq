APP_NAME="Presensi Kajian Walsan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kajian.griyaquran.web.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================================
# DATABASE - MariaDB
# ============================================================
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kajian_walsan
DB_USERNAME=root
DB_PASSWORD=
# DB_SSLMODE=prefer

# ============================================================
# REDIS — dipakai untuk session, cache, antrian job, dan cache Pulse.
# Driver ini jauh lebih cepat daripada database, dan mengurangi
# beban query DB di setiap request Livewire / login / scan QR.
# Host default 'redis' = nama service di docker-compose.yml.
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Pulse: simpan metrics di DB (tabel pulse_* sudah dimigrasi),
# tapi pakai Redis untuk cache/lock Pulse agar tidak menambah beban DB.
PULSE_STORAGE_DRIVER=database
PULSE_INGEST_DRIVER=storage
PULSE_CACHE_DRIVER=redis

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
ADMIN_WHATSAPP=6281234567890

# Cloudinary (untuk penyimpanan file bukti)
CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=kajian-walsan

# n8n Webhook
N8N_WEBHOOK_ENABLED=false
N8N_WEBHOOK_URL=
N8N_PASSWORD_RESET_WEBHOOK_URL=
N8N_PASSWORD_RESET_SECRET=change-this-long-random-secret

# Hermes Agent API
# Kirim sebagai header: X-Hermes-Secret
HERMES_AGENT_SECRET=change-this-long-random-hermes-secret

# ============================================================
# Google OAuth (Laravel Socialite)
# Buat di: https://console.cloud.google.com > APIs & Services > Credentials
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://kajian.griyaquran.web.id/auth/google/callback

# ============================================================
# NOTE: setelah ubah driver di atas, jalankan ulang
#   php artisan config:cache
#   php artisan route:cache
# agar perubahan environment terbake ke cache produksi.
# ============================================================

# Web Push / PWA Notification (VAPID)
# Generate with: php -r "require 'vendor/autoload.php'; print_r(Minishlink\\WebPush\\VAPID::createVapidKeys());"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@kajian.griyaquran.web.id

